# WINVOICE 環境変数サンプル
# このファイルを .env にコピーして値を入力してください（.env はgit管理外）
#   cp .env.example .env

# ─── netkeiba ログイン情報（Myロジック分析・馬メモ取得に必要）───
# 通常はWINVOICE本体の「netkeiba ログイン設定」でログインした
# ブラウザセッションを自動利用するため空でも動作します。
# セッション切れ時の自動再ログインに使う場合のみ設定してください。
NETKEIBA_LOGIN_ID=
NETKEIBA_PASSWORD=

# （後方互換：既存のIPAT自動ログインで使用。上と同じ値でOK）
NETKEIBA_USER=
NETKEIBA_PASS=

# ─── 競馬ブック（厩舎の話の全頭取得に必要・任意）───
# 未設定でも旧プロジェクトの keibabook_config.json があれば自動利用します。
# どちらも無い場合、厩舎の話は先頭数頭分のみ表示されます。
KEIBABOOK_LOGIN_ID=
KEIBABOOK_PASSWORD=

# ─── アプリ簡易認証 ───
# 設定すると起動時にパスワード入力を求めます。
# ローカル利用のみなら空でも可。外部公開する場合は必ず設定してください。
APP_PASSWORD=

# ─── AI自然言語解釈（任意）───
ANTHROPIC_API_KEY=
